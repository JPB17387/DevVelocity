{
  "name": "devvelocity-vscode-extension",
  "displayName": "DevVelocity",
  "publisher": "paulcodebreaker",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpb17387/DevVelocity.git"
  },
  "version": "1.0.0",
  "description": "A productivity tool that tracks your coding time, streak, and habits, providing detailed stats and weekly progress to help you optimize your workflow and enhance focus.",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "public/assets/DevVelocity.png",
  "contributes": {
    "commands": [
      {
        "command": "devvelocity.showDashboard",
        "title": "DevVelocity: Show Stats",
        "icon": "$(graph)"
      },
      {
        "command": "devvelocity.debug.showSessions",
        "title": "DevVelocity: Show Raw Sessions"
      },
      {
        "command": "devvelocity.debug.clearSessions",
        "title": "DevVelocity: Clear Sessions"
      },
      {
        "command": "devvelocity.debug.simulateSession",
        "title": "DevVelocity: Simulate Session"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "paulcodebreaker",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.6"
  }
}
